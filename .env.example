# ============ SautiSafari Advanced — configuration ============
# Copy this file to ".env" and edit. Everything has a sensible default.

# ---- Speech recognition (faster-whisper) ----
# tiny | base | small | medium   (small = good CPU balance; tiny = fastest)
ASR_MODEL=small
ASR_DEVICE=cpu          # cpu | cuda
ASR_COMPUTE=int8        # int8 for cpu, float16 for cuda

# ---- Retrieval (RAG) ----
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
DATA_DIR=data
RAG_THRESHOLD=0.16
TOP_K=5

# ---- Translation ----
# google = deep-translator (accurate, needs internet) | llm = use the LLM (offline)
TRANSLATE_PROVIDER=google

# ---- Language model ----
# ollama (local, default) | openai (any OpenAI-compatible API) | none (templates)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434/api/generate

# Only needed if LLM_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Text to speech ----
ENABLE_TTS=1
TTS_MAX_CHARS=900

# ---- Maps / geo (public demo servers; self-host for production) ----
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
OSRM_URL=https://router.project-osrm.org
GEO_USER_AGENT=SautiSafari/2.0 (your-email@example.com)
MAP_CENTER_LAT=-6.1659
MAP_CENTER_LON=39.2026

# ---- Server ----
HOST=127.0.0.1
PORT=7860
